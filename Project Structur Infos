    // Verhindert das Einbetten in iFrames (Schutz vor Clickjacking)
    newResponse.headers.set("X-Frame-Options", "DENY");
    newResponse.headers.set("Content-Security-Policy", "frame-ancestors 'none'; default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; object-src 'none';");

