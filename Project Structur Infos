1. Das IDE-Scanner-Skript (scripts/ide-tool-scanner.js)

Dieses Node.js-Skript läuft direkt im Hintergrund deiner IDE. Es scannt Konfigurationsdateien (package.json, Dockerfiles, .yml), extrahiert die verwendeten Tools und schreibt sie strukturiert in die Matrix.
JavaScript

// scripts/ide-tool-scanner.js
const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

const WORKSPACE_DIR = path.resolve(__dirname, '../');
const README_PATH = path.join(WORKSPACE_DIR, 'README.md');

console.log("🌟 Starte IDE-Workspace-Scan für sTarLighTsMoveMenTs...");

const toolMatrix = [];

// 1. NPM Dependencies scannen (falls vorhanden)
const packageJsonPath = path.join(WORKSPACE_DIR, 'package.json');
if (fs.existsSync(packageJsonPath)) {
    const pkg = require(packageJsonPath);
    const deps = { ...pkg.dependencies, ...pkg.devDependencies };
    for (const [name, version] of Object.entries(deps)) {
        toolMatrix.push(`| **${name}** | NPM Package / Node Ebene | \`npm install ${name}\` | [npmjs.com/package/${name}](https://www.npmjs.com/package/${name}) |`);
    }
}

// 2. Docker & YML Files scannen
function scanDockerFiles() {
    const files = fs.readdirSync(WORKSPACE_DIR);
    files.forEach(file => {
        if (file.includes('Dockerfile') || file.endsWith('.yml') || file.endsWith('.yaml')) {
            const content = fs.readFileSync(path.join(WORKSPACE_DIR, file), 'utf-8');
            const imageMatches = content.match(/image:\s*([^\s]+)|FROM\s+([^\s]+)/g);
            if (imageMatches) {
                imageMatches.forEach(match => {
                    const cleanName = match.replace(/image:\s*|FROM\s+/, '').trim();
                    toolMatrix.push(`| **${cleanName}** | Container Ebene | \`docker pull ${cleanName}\` | [Docker Hub](https://hub.docker.com/search?q=${cleanName.split(':')[0]}) |`);
                });
            }
        }
    });
}
scanDockerFiles();

// 3. Fallback für spezifische Tools (t2, d7 etc.) in lokalen Skripten
function scanCustomTools() {
    try {
        // Sucht nach typischen Installationsbefehlen in .sh und .js Dateien
        const searchCmd = process.platform === 'win32'
            ? 'findstr /S /R "apt-get install .* brew install .*" *.sh *.js'
            : 'grep -rE "apt-get install|brew install" . --exclude-dir=node_modules';

        const result = execSync(searchCmd, { cwd: WORKSPACE_DIR, encoding: 'utf-8' });
        const lines = result.split('\n');
        lines.forEach(line => {
            if(line.includes('install')) {
                const parts = line.split('install');
                const toolName = parts[1].trim().split(' ')[0]; // Nimmt das erste Wort nach 'install'
                if(toolName && toolName.length > 1 && !toolMatrix.some(t => t.includes(`**${toolName}**`))) {
                    toolMatrix.push(`| **${toolName}** | System Tool | \`${parts[0].trim().split(':').pop()} install ${toolName}\` | Lokale Extraction |`);
                }
            }
        });
    } catch (e) {
        // Ignore errors if grep finds nothing
    }
}
scanCustomTools();

// 4. Matrix aufbauen und doppelte Einträge filtern
const uniqueMatrix = [...new Set(toolMatrix)].sort();

const matrixHeader = `
| Tool / Service | Funktion / PNIA Ebene | Installations-Skript (Copy & Paste) | Repository / Herkunft |
| :--- | :--- | :--- | :--- |
`;

const newTableContent = matrixHeader.trim() + '\n' + uniqueMatrix.join('\n');

// 5. README.md aktualisieren
if (fs.existsSync(README_PATH)) {
    let readmeContent = fs.readFileSync(README_PATH, 'utf-8');

    // Sucht den Bereich zwischen der Überschrift der Matrix und dem nächsten Abschnitt
    const startMarker = "## 5. Toolchain, Installation & Deployment Matrix";
    const endMarker = "## 6. Validation & Certificates";

    const startIndex = readmeContent.indexOf(startMarker);
    const endIndex = readmeContent.indexOf(endMarker);

    if (startIndex !== -1 && endIndex !== -1) {
        const before = readmeContent.substring(0, startIndex + startMarker.length + 1);
        const after = readmeContent.substring(endIndex);

        const updatedReadme = `${before}\n${newTableContent}\n\n${after}`;
        fs.writeFileSync(README_PATH, updatedReadme, 'utf-8');
        console.log("✅ README.md erfolgreich durch die IDE aktualisiert!");
    } else {
        console.log("⚠️ Konnte die Sektion in der README.md nicht finden.");
    }
} else {
    console.log("⚠️ README.md nicht gefunden.");
}

