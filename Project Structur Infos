export default {
  async fetch(request, env, ctx) {
    const response = await fetch(request);

    // Response klonen, um Header modifizieren zu können
    let newResponse = new Response(response.body, response);

    // 🔒 Strikte Security Headers
    // Verhindert das Einbetten in iFrames (Schutz vor Clickjacking)
    newResponse.headers.set("X-Frame-Options", "DENY");
    newResponse.headers.set("Content-Security-Policy", "frame-ancestors 'none'; default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; object-src 'none';");

    // Verhindert MIME-Type Sniffing
    newResponse.headers.set("X-Content-Type-Options", "nosniff");

    // Erzwingt HTTPS (HSTS) für 1 Jahr inklusive Subdomains
    newResponse.headers.set("Strict-Transport-Security", "max-age=31536000; includeSubDomains; preload");

    // Reduziert Informationen beim Weiterleiten (Referrer)
    newResponse.headers.set("Referrer-Policy", "strict-origin-when-cross-origin");

    // Blockiert Hardware-Zugriffe (Kamera, Mikrofon, GPS)
    newResponse.headers.set("Permissions-Policy", "camera=(), microphone=(), geolocation=()");

    return newResponse;
  },
};

