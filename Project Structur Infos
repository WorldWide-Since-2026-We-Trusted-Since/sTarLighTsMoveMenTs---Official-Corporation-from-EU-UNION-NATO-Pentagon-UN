    document.body.style.userSelect = "none";
    document.body.style.webkitUserSelect = "none";
    document.body.style.msUserSelect = "none";

    // 3. Tastenkombinationen für DevTools blockieren (F12, Ctrl+Shift+I/C/J, Ctrl+U)
    document.addEventListener('keydown', function(e) {
        if (e.key === 'F12' ||
           (e.ctrlKey && e.shiftKey && (e.key === 'I' || e.key === 'J' || e.key === 'C')) ||
           (e.ctrlKey && e.key === 'U')) {
            e.preventDefault();
        }
    });

    // 4. DOM Mutation Observer (Verhindert nachträgliche Code-Injektion)
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            // Erkennt und blockiert das Einfügen von fremden Script-Tags ins DOM
            mutation.addedNodes.forEach((node) => {
                if (node.tagName === 'SCRIPT' && !node.src.includes('pLedge250freedom.gov.eu')) {
                    node.remove();
                    console.error("🔒 Sicherheitsverstoß: Fremdes Script wurde durch DOM-Protection blockiert.");
                }
            });
        });
    });

    observer.observe(document.body, { childList: true, subtree: true });
    console.log("🔒 Client-Side Security initialisiert.");
})();

