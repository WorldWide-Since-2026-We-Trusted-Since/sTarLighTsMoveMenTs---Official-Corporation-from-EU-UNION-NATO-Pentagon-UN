# =============================================================================
# 🔒 HNOSS Zero Trust Environment Configuration
# .env.example - NICHTS ÄNDERN OHNE AUTHORIZIERUNG!
# =============================================================================
# Diese Datei dient als Vorlage - KEINE echten Secrets!
# 
# Deployment erfolgt ausschließlich über:
#   wrangler login   (browser-basierte Authentifizierung)
#   wrangler deploy  (nutzt ~/.wrangler/config/default.toml)
# =============================================================================

# Cloudflare / Wrangler Konfiguration
# Wird über wrangler login automatisch konfiguriert
# CF_ACCOUNT_ID=
# CF_ZONE_ID=

# HNOSS Domain Signatur (optional)
# Wird als Wrangler Secret gesetzt: wrangler secret put HNOSS_DOMAIN_SIGNATURE
# HNOSS_DOMAIN_SIGNATURE=

# Tunnel Konfiguration (wird lokal erstellt)
# Siehe: scripts/ssh-tunnel.sh
# TUNNEL_TOKEN=

# =============================================================================
# WICHTIG: NIEMALS echte Werte in diese Datei eintragen!
# Alle echten Secrets werden als Wrangler Secrets hinterlegt!
# =============================================================================