/* data: KF (float-Vektor). Rueckgabe: normalisierter State als KF. */

K native_quantum_project(K data) {

    if (data->t != KF) return krr("type");        /* nur Float-Vektor */

    J n = data->n;

    double norm = 0.0;

    for (J i = 0; i < n; i++) norm += kF(data)[i] * kF(data)[i];

