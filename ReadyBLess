# quantum_encode.py

import numpy as np

import pennylane as qml


def amplitude_encode(data: np.ndarray, n_qubits: int) -> np.ndarray:

    """Klassische Daten -> normalisierter Amplituden-Vektor (Quanten-String)."""

    dim = 2 ** n_qubits

    v = np.zeros(dim, dtype=np.float64)

    v[: min(len(data), dim)] = np.asarray(data, dtype=np.float64)[:dim]

    norm = np.linalg.norm(v)

    if norm == 0:

        raise ValueError("Null-Vektor kann nicht encodiert werden")

    return v / norm


dev = qml.device("default.qubit", wires=4)


@qml.qnode(dev)

def projection(state):

    qml.AmplitudeEmbedding(state, wires=range(4), normalize=False)

    return [qml.expval(qml.PauliZ(w)) for w in range(4)]

```


