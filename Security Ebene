// Neuer Endpoint: Ban-Liste abrufen
app.get('/api/get-bans', (req, res) => {
    if (fs.existsSync('bans.json')) {
        const bans = JSON.parse(fs.readFileSync('bans.json'));
        res.json(bans);
    } else {
        res.json([]);
    }
});

// Endpoint zum Hinzufügen eines Bans (wird vom Worker aufgerufen)
app.post('/_api/security/ban', (req, res) => {
    const { ip, reason } = req.body;
    let bans = fs.existsSync('bans.json') ? JSON.parse(fs.readFileSync('bans.json')) : [];
    bans.push({ ip, reason, timestamp: new Date().toISOString() });
    fs.writeFileSync('bans.json', JSON.stringify(bans));
    res.sendStatus(200);
});

