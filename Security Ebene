2. Cloudflare Worker (cloudflare-worker.js)

Dieser Worker sitzt an der Edge und schützt jede Anfrage an deine URL, noch bevor sie deinen Server (Origin) erreicht.
JavaScript

export default {
  async fetch(request, env, ctx) {
    const response = await fetch(request);

    // Kopiere die Response, um Header modifizieren zu können
    let newResponse = new Response(response.body, response);

    // 🔒 Security Headers (Verhindert Framing, Sniffing und erzwingt HTTPS)
    // Erlaubt das Laden von eigenen Scripts, blockiert aber fremde iframes und externe Ressourcen
    newResponse.headers.set("Content-Security-Policy", "default-src 'self' 'unsafe-inline'; frame-ancestors 'none'; object-src 'none';");
    newResponse.headers.set("X-Content-Type-Options", "nosniff");
    newResponse.headers.set("X-Frame-Options", "DENY");
    newResponse.headers.set("Strict-Transport-Security", "max-age=31536000; includeSubDomains; preload");
    newResponse.headers.set("Referrer-Policy", "strict-origin-when-cross-origin");
    newResponse.headers.set("Permissions-Policy", "camera=(), microphone=(), geolocation=()");

    return newResponse;
  },
};

3. Tunnel Setup Skript (scripts/ssh-tunnel.sh)

Dieses Bash-Skript richtet den cloudflared-Tunnel auf deinem Server ein, ohne dass du jemals einen Key kopieren musst. Es führt dich durch den sicheren OAuth-Prozess im Browser.
Bash

#!/bin/bash
# scripts/ssh-tunnel.sh
# Zero-Trust Setup für den Cloudflare Tunnel (Ohne harte API-Keys)

TUNNEL_NAME="pLedge-tunnel"
DOMAIN="pLedge250freedom.gov.eu"
LOCAL_PORT=8080 # Ändere dies auf den Port, auf dem dein lokaler Webserver läuft

echo "🔒 Starte Zero-Trust Tunnel Setup für $DOMAIN..."

# 1. Cloudflared installieren (falls nicht vorhanden)
if ! command -v cloudflared &> /dev/null; then
    echo "Installiere cloudflared..."
    curl -L --output cloudflared.deb https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64.deb
    sudo dpkg -i cloudflared.deb
    rm cloudflared.deb
fi

# 2. Login (Öffnet Browser für OAuth - Keine Keys im Code!)
echo "Bitte im Browser authentifizieren..."
cloudflared tunnel login

# 3. Tunnel erstellen
echo "Erstelle Tunnel: $TUNNEL_NAME"
cloudflared tunnel create $TUNNEL_NAME

# 4. Config generieren (lokal auf dem Server, außerhalb des Repos)
TUNNEL_UUID=$(cloudflared tunnel list | grep $TUNNEL_NAME | awk '{print $1}')
CONFIG_DIR="$HOME/.cloudflared"

cat <<EOF > $CONFIG_DIR/config.yml
tunnel: $TUNNEL_UUID
credentials-file: $CONFIG_DIR/$TUNNEL_UUID.json

ingress:
  - hostname: $DOMAIN
    service: http://localhost:$LOCAL_PORT
  - service: http_status:404
EOF

echo "✅ Konfiguration erstellt unter $CONFIG_DIR/config.yml"

# 5. Tunnel Route setzen und als Service installieren
cloudflared tunnel route dns $TUNNEL_NAME $DOMAIN
cloudflared service install
systemctl start cloudflared

echo "🚀 Tunnel ist aktiv und läuft als Systemdienst."

4. Client-Side DOM Protection (scripts/security-headers.js)

Dieses Skript musst du im <head> oder am Ende des <body> deiner HTML-Dateien einbinden (<script src="/scripts/security-headers.js"></script>). Es wehrt "DOM Scan & Read"-Versuche von Scrapern und neugierigen Nutzern ab.
JavaScript

// scripts/security-headers.js
// Client-Side DOM Protection, Anti-Copy & Anti-DevTools

(function() {
    // 1. Anti-Copy, Rechtsklick- & Ausschneiden-Sperre
    const preventAction = (e) => e.preventDefault();
    document.addEventListener('contextmenu', preventAction);
    document.addEventListener('copy', (e) => {
        preventAction(e);
        console.warn("Kopieren ist auf pLedge250freedom.gov.eu sicherheitsbedingt deaktiviert.");
    });
    document.addEventListener('cut', preventAction);
    document.addEventListener('paste', preventAction);

    // 2. Schutz vor Textauswahl
    document.onselectstart = () => false;
    document.body.style.userSelect = "none";
    document.body.style.webkitUserSelect = "none";
    document.body.style.msUserSelect = "none";

    // 3. Tastenkombinationen für DevTools blockieren (F12, Ctrl+Shift+I/C/J, Ctrl+U)
    document.addEventListener('keydown', function(e) {
        if (e.key === 'F12' ||
           (e.ctrlKey && e.shiftKey && (e.key === 'I' || e.key === 'J' || e.key === 'C')) ||
           (e.ctrlKey && e.key === 'U')) {
            e.preventDefault();
        }
    });

    // 4. DOM Mutation Observer (Verhindert nachträgliche Code-Injektion)
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            // Erkennt und blockiert das Einfügen von fremden Script-Tags ins DOM
            mutation.addedNodes.forEach((node) => {
                if (node.tagName === 'SCRIPT' && !node.src.includes('pLedge250freedom.gov.eu')) {
                    node.remove();
                    console.error("🔒 Sicherheitsverstoß: Fremdes Script wurde durch DOM-Protection blockiert.");
                }
            });
        });
    });

    observer.observe(document.body, { childList: true, subtree: true });
    console.log("🔒 Client-Side Security initialisiert.");
})();

