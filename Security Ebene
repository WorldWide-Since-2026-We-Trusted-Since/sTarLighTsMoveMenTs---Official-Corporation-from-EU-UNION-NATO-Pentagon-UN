// scripts/security-headers.js
// Client-Side DOM Protection, Anti-Copy & Anti-DevTools

(function() {
    // 1. Anti-Copy, Rechtsklick- & Ausschneiden-Sperre
    const preventAction = (e) => e.preventDefault();
    document.addEventListener('contextmenu', preventAction);
    document.addEventListener('copy', (e) => {
        preventAction(e);
        console.warn("Kopieren ist auf pLedge250freedom.gov.eu sicherheitsbedingt deaktiviert.");
    });
    document.addEventListener('cut', preventAction);
    document.addEventListener('paste', preventAction);

    // 2. Schutz vor Textauswahl
