    document.addEventListener('contextmenu', function(e) {
        e.preventDefault();
    });

    // 2. Verhindere Textauswahl, Kopieren und Drag & Drop
    document.addEventListener('selectstart', function(e) { e.preventDefault(); });
    document.addEventListener('copy', function(e) {
        e.preventDefault();
        // Überschreibt die Zwischenablage mit einem Leerstring, falls doch etwas durchkommt
        if (navigator.clipboard) { navigator.clipboard.writeText(''); }
    });
    document.addEventListener('cut', function(e) { e.preventDefault(); });
    document.addEventListener('dragstart', function(e) { e.preventDefault(); });

    // 3. Blockiere gängige DevTools Tastenkombinationen (F12, Ctrl+Shift+I, Ctrl+U)
    document.addEventListener('keydown', function(e) {
        if (e.key === 'F12' ||
           (e.ctrlKey && e.shiftKey && e.key === 'I') ||
           (e.ctrlKey && e.shiftKey && e.key === 'J') ||
           (e.ctrlKey && e.key === 'U') ||
           (e.ctrlKey && e.shiftKey && e.key === 'C')) {
            e.preventDefault();
        }
    });

    // 4. DOM Mutation Observer (Schutz vor Code-Injektion)
    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            // Blockiere nachträglich injizierte Skripte (z.B. durch Browser-Erweiterungen oder Console)
            if (mutation.addedNodes.length > 0) {
                for (let i = 0; i < mutation.addedNodes.length; i++) {
                    const node = mutation.addedNodes[i];
                    if (node.tagName === 'SCRIPT' && !node.getAttribute('data-secure-core')) {
                        console.warn('🔒 Unerlaubte DOM-Manipulation blockiert.');
                        node.remove(); // Entfernt das fremde Skript sofort
                    }
                }
            }
        });
    });

    // Überwache das gesamte Dokument
    window.addEventListener('DOMContentLoaded', () => {
        observer.observe(document.documentElement, {
            childList: true,
            subtree: true
        });
    });
})();

